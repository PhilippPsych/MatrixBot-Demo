# Ella-Bot STAGING Environment
# Kopiere diese Datei als .env.staging und befuelle mit echten Werten.
# NIEMALS echte Credentials committen!

# Matrix Staging-Account (z.B. @ella-staging:demokratiebot.de)
MATRIX_HOMESERVER=https://demokratiebot.de
MATRIX_USER_ID=@ella-staging:demokratiebot.de
MATRIX_ACCESS_TOKEN=HIER_STAGING_TOKEN_EINTRAGEN
MATRIX_DEVICE_ID=HIER_STAGING_DEVICE_ID_EINTRAGEN

# Sidecar-Port fuer Staging (Prod: 8010)
MATRIX_SIDECAR_LISTEN=127.0.0.1:8011
MATRIX_SIDECAR_URL=http://127.0.0.1:8011

# AI Service
ANTHROPIC_API_KEY=HIER_API_KEY_EINTRAGEN

# Staging-Modi
TEST_MODE=true
PILOT_MODE=false
